generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ENGINEER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projects  Project[]
  reports   Report[]
  
  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  ENGINEER
  VIEWER
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime
  targetDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id])
  
  benchmarks  Benchmark[]
  reports     Report[]
  
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

model Benchmark {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Product Info
  productName       String
  manufacturer      String
  modelNumber       String?
  category          String   // Engine, Transmission, Suspension, etc.
  year              Int?
  origin            String   // Country of manufacture
  
  // Cost Analysis
  estimatedCost     Decimal? @db.Decimal(10, 2)
  currency          String   @default("USD")
  costBreakdown     Json?    // Detailed cost structure
  
  // Performance Metrics
  weight            Decimal? @db.Decimal(10, 3) // kg
  dimensions        Json?    // {length, width, height}
  performanceScore  Decimal? @db.Decimal(5, 2)
  efficiencyRating  String?
  
  // Quality & NVH
  qualityScore      Int?     @db.SmallInt // 1-10
  nvhRating         String?  // Noise, Vibration, Harshness
  durabilityScore   Int?     @db.SmallInt
  
  // Features
  features          Json?    // Array of feature objects
  technologyUsed    String[]
  
  // Teardown Data
  teardownDate      DateTime?
  teardownLocation  String?
  teardownEngineer  String?
  
  // Manufacturing
  assemblyTime      Int?     // Minutes
  dfmaScore         Int?     @db.SmallInt // Design for Manufacturing/Assembly
  manufacturingNotes String?
  
  // Supplier Info
  makeVsBuy         MakeBuyDecision?
  supplierStrategy  String?
  standardParts     Json?    // List of standard vs proprietary parts
  
  // Media
  images            Media[]
  videos            Media[]
  documents         Media[]
  
  // Analysis
  swotAnalysis      Json?
  competitivePosition String?
  recommendations   String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  components        Component[]
  bomItems          BOMItem[]
  
  @@map("benchmarks")
}

enum MakeBuyDecision {
  MAKE
  BUY
  HYBRID
}

model Component {
  id            String    @id @default(uuid())
  benchmarkId   String
  benchmark     Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)
  
  name          String
  partNumber    String?
  material      String?
  weight        Decimal?  @db.Decimal(10, 3)
  dimensions    Json?
  function      String?
  cost          Decimal?  @db.Decimal(10, 2)
  supplier      String?
  isProprietary Boolean   @default(false)
  images        String[]  // URLs
  
  createdAt     DateTime  @default(now())
  
  @@map("components")
}

model BOMItem {
  id          String    @id @default(uuid())
  benchmarkId String
  benchmark   Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)
  
  itemNumber  String
  description String
  quantity    Int
  unit        String
  material    String?
  weight      Decimal?  @db.Decimal(10, 3)
  cost        Decimal?  @db.Decimal(10, 2)
  supplier    String?
  standardPart Boolean  @default(true)
  
  @@map("bom_items")
}

model Media {
  id          String    @id @default(uuid())
  benchmarkId String
  benchmark   Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)
  
  type        MediaType
  url         String
  thumbnail   String?
  title       String?
  description String?
  metadata    Json?     // EXIF data, dimensions, etc.
  uploadedAt  DateTime  @default(now())
  
  @@map("media")
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  CAD
}

model Report {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id])
  
  title       String
  type        ReportType
  content     Json     // Structured report data
  pdfUrl      String?
  generatedAt DateTime @default(now())
  
  @@map("reports")
}

enum ReportType {
  TEARDOWN
  COMPARATIVE
  COST_ANALYSIS
  TECHNICAL
  EXECUTIVE_SUMMARY
}