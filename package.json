{
  "name": "basic-user-management",
  "version": "0.1.0",
  "private": true,
  "description": "Basic user management app with Express backend and simple frontend",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "qa": "NODE_ENV=qa node server.js",
    "prod": "NODE_ENV=production node server.js",
    "codegen": "node scripts/generate-types.cjs",
    "check:types": "node scripts/check-types.cjs",
    "db:seed": "node scripts/seed-components.js",
    "db:verify": "node scripts/verify-components.js",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "build:server": "echo 'Server is already built for Node.js'",
    "deploy:dev": "./setup-env.sh dev && npm run build",
    "deploy:qa": "./setup-env.sh qa && npm run build",
    "deploy:prod": "./setup-env.sh prod && npm run build"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.1.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0",
    "sql.js": "^1.10.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^13.1.1"
  }
}
